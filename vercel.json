{
  "version": 2,
  "builds": [
    { "src": "index.html",                  "use": "@vercel/static" },
    { "src": ".well-known/farcaster.json",  "use": "@vercel/static" },
    { "src": "icon.png",                    "use": "@vercel/static" },
    { "src": "splash.png",                  "use": "@vercel/static" },
    { "src": "og.png",                      "use": "@vercel/static" }
  ],
  "routes": [
    {
      "src": "/.well-known/farcaster.json",
      "dest": "/.well-known/farcaster.json",
      "headers": { "Content-Type": "application/json" }
    },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",           "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options",    "value": "nosniff" },
        { "key": "Referrer-Policy",           "value": "strict-origin-when-cross-origin" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self' https://fonts.googleapis.com https://fonts.gstatic.com https://cdnjs.cloudflare.com; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; connect-src 'self' https://mainnet.base.org wss://mainnet.base.org https://*.infura.io https://*.alchemy.com; frame-src 'self' blob:;"
        }
      ]
    }
  ]
}
